{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "pyjobkit worker (sqlite)",
      "type": "debugpy",
      "request": "launch",
      "module": "pyjobkit.cli",
      "args": [
        "--dsn", "sqlite+aiosqlite:///jobs.db",
        "--concurrency", "4",
        "--log-level", "DEBUG"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "pytest: all",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-v"],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
